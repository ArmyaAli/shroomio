# CLI flags override these environment variables.
SHROOM_SERVER_BIND=0.0.0.0
SHROOM_SERVER_PORT=7777
SHROOM_SERVER_DB_PATH=/var/lib/shroomio/shroomio.db
SHROOM_SERVER_SNAPSHOT_RATE=15

# Set these to advertise through a separately operated directory server.
# SHROOM_DIRECTORY_HOST=directory.example.com
# SHROOM_DIRECTORY_PORT=7778
# SHROOM_SERVER_NAME=East Arena
